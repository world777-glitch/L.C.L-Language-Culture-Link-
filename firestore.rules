rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "lhbin777@gmail.com")
      );
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'contact', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.contact is string && data.contact.size() > 0 && data.contact.size() < 200;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if isOwner(uid) || isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isAdmin();
      allow create: if isValidInquiry(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if isOwner(resource.data.studentUid) || isAdmin();
      allow create: if isAuthenticated() && (request.resource.data.studentUid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /downloads/{downloadId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(resource.data.userUid);
    }

    match /community/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(resource.data.userUid);
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
