rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "lhbin777@gmail.com" && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isRecent(time) {
      return time > request.time - duration.value(5, 'm') && time < request.time + duration.value(5, 'm');
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'contact', 'createdAt']) &&
             isValidString(data.name, 1, 100) &&
             isValidString(data.contact, 1, 200) &&
             isRecent(data.createdAt);
    }

    function isValidPost(data) {
      return data.keys().hasAll(['title', 'content', 'userUid', 'createdAt']) &&
             isValidString(data.title, 1, 200) &&
             isValidString(data.content, 1, 10000) &&
             data.userUid == request.auth.uid &&
             isRecent(data.createdAt);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['content', 'userUid', 'postId', 'createdAt']) &&
             isValidString(data.content, 1, 2000) &&
             data.userUid == request.auth.uid &&
             isRecent(data.createdAt);
    }

    function isValidVisit(data) {
      return data.keys().hasAll(['timestamp', 'path']) &&
             isRecent(data.timestamp);
    }

    function isPublished(data) {
      return !('status' in data) || data.status == 'published';
    }
    
    function canReadResource(data) {
      return isAdmin() || isPublished(data);
    }

    function canReadPost(data) {
      return isAdmin() || isPublished(data) || (isAuthenticated() && data.userUid == request.auth.uid);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && request.resource.data.role == 'student';
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if isAdmin();
    }

    match /inquiries/{inquiryId} {
      allow read: if isAdmin();
      allow create: if isValidInquiry(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if isOwner(resource.data.studentUid) || isAdmin();
      allow create: if isAuthenticated() && (request.resource.data.studentUid == request.auth.uid || isAdmin()) && isRecent(request.resource.data.createdAt);
      allow update, delete: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow read: if isOwner(resource.data.studentUid) || isAdmin();
      allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if canReadResource(resource.data);
      allow write: if isAdmin();
    }

    match /downloads/{downloadId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid && isRecent(request.resource.data.timestamp);
    }

    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidComment(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || isOwner(resource.data.userUid);
    }

    match /community/{postId} {
      allow read: if canReadPost(resource.data);
      allow create: if isAuthenticated() && isValidPost(request.resource.data);
      allow update: if isAdmin() || (isOwner(resource.data.userUid) && isValidPost(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt);
      allow delete: if isAdmin() || isOwner(resource.data.userUid);
    }

    match /levelTests/{testId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteContent/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /visits/{visitId} {
      allow read: if isAdmin();
      allow create: if isValidVisit(request.resource.data);
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid && isRecent(request.resource.data.createdAt);
      allow delete: if isAuthenticated() && resource.data.userUid == request.auth.uid;
    }

    match /bookmarks/{bookmarkId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userUid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userUid == request.auth.uid && isRecent(request.resource.data.createdAt);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userUid == request.auth.uid);
    }
  }
}
